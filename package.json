{
  "name": "pepe-studio-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "tauri:run": "cargo run --manifest-path src-tauri/Cargo.toml",
    "tauri:dev": "powershell -NoProfile -Command \"Start-Process npm -ArgumentList 'run','dev' -WorkingDirectory 'E:\\CustomApp'; Start-Process npm -ArgumentList 'run','tauri:run' -WorkingDirectory 'E:\\CustomApp'\"",
    "tauri:build": "next build && npx tauri build",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^1.5.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.517.0",
    "next": "^14.2.35",
    "pdfjs-dist": "^5.1.91",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tauri-apps/cli": "^1.5.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.42",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.2"
  }
}

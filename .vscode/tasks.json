{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Tauri Dev",
            "type": "shell",
            "command": "npm run tauri:dev",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "owner": "typescript",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^(.+)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+TS(\\d+):\\s+(.+)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "code": 5,
                        "message": 6
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^\\s*ready started server",
                        "endsPattern": "^\\s*✓ Ready in"
                    }
                },
                {
                    "owner": "next",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^\\s*(.+\\.tsx?)\\s*\\((\\d+):(\\d+)\\)",
                        "file": 1,
                        "line": 2,
                        "column": 3
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^\\s*ready started server",
                        "endsPattern": "^\\s*✓ Ready in"
                    }
                },
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "🔍 Lint (ESLint)",
            "type": "shell",
            "command": "npx eslint src/ --ext .ts,.tsx --format stylish",
            "group": "test",
            "problemMatcher": "$eslint-stylish",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "🦀 Cargo Check (Rust)",
            "type": "shell",
            "command": "cargo check",
            "options": {
                "cwd": "${workspaceFolder}/src-tauri"
            },
            "group": "build",
            "problemMatcher": "$rustc",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "🔨 Build Complet",
            "type": "shell",
            "command": "npm run build",
            "group": "build",
            "problemMatcher": "$tsc",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "✅ TypeScript Check",
            "type": "shell",
            "command": "npx tsc --noEmit",
            "group": "build",
            "problemMatcher": "$tsc",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "🧹 Format (Prettier)",
            "type": "shell",
            "command": "npx prettier --write \"src/**/*.{ts,tsx,css,json}\"",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
